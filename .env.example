# Copy this file to `.env` and fill in your keys (for local runs).
# In Google Colab, use the Secrets panel (key icon) instead — add each key as a
# secret with the same name and enable notebook access.
# `.env` is git-ignored, so your keys are never committed.

# --- LLM provider keys (set the one matching PROVIDER in the notebook) ---
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Human-annotation keys (only needed when COLLECT_HUMAN = True) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
QUALTRICS_API_KEY=
QUALTRICS_API_URL=
PROLIFIC_API_KEY=
